{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "outDir": "../dist-test",
        "rootDir": "..",
        "noEmit": false,
        "plugins": [
            {
                "transform": "../dist/json/TsTransformer/index.js",
                "after": true
            }
        ]
    },
    "include": [
        "**/*.ts",
        "../src/**/*.ts"
    ],
    "exclude": [
        "../node_modules"
    ]
}
