{
    "compilerOptions": {
        "strict": true,
        "isolatedModules": true,
        "allowSyntheticDefaultImports": true,
        "declaration": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "lib": ["ESNext", "WebWorker", "ES2015.Reflect", "DOM"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "skipDefaultLibCheck": true,
        "skipLibCheck": true,
        "target": "ESNext",
        "outDir": "dist",
        "rootDir": "src",
        "sourceMap": true,
        "importHelpers": true,
        "customConditions": ["monorepo"]
    },

    "exclude": [
        "dist",
        "node_modules",
        "test"
    ],

    "compileOnSave": false
}
